<%- include('../layouts/head') %>
<%- include('../layouts/sidebar', { active: 'employees' }) %>
<%- include('../layouts/navbar', { title: 'Manajemen Pegawai' }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><i class="bi bi-person-badge me-2"></i>Manajemen Pegawai</h4>
  <a href="/employees/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Tambah Pegawai</a>
</div>
<div class="card border-0 shadow-sm">
  <div class="card-body">
    <form class="row g-2 mb-3" method="get">
      <div class="col-md-4">
        <input type="text" name="search" class="form-control" placeholder="Cari nama / email..." value="<%= typeof search !== 'undefined' ? search : '' %>">
      </div>
      <div class="col-auto">
        <button class="btn btn-outline-primary"><i class="bi bi-search"></i> Cari</button>
        <a href="/employees" class="btn btn-outline-secondary">Reset</a>
      </div>
    </form>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-light">
          <tr><th>#</th><th>Foto</th><th>Nama</th><th>Email</th><th>Telepon</th><th width="140">Aksi</th></tr>
        </thead>
        <tbody>
          <% var empList = typeof employees !== 'undefined' ? employees : []; %>
          <% if (empList.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-4">Tidak ada data.</td></tr>
          <% } else { %>
          <% empList.forEach(function(e, i) { %>
          <tr>
            <td><%= i + 1 %></td>
            <td>
              <% if (e.photo) { %>
              <img src="/uploads/<%= e.photo %>" alt="Foto" class="avatar-sm">
              <% } else { %>
              <span class="avatar-sm d-inline-block bg-light text-muted text-center lh-1">-</span>
              <% } %>
            </td>
            <td><%= e.name %></td>
            <td><%= e.email %></td>
            <td><%= e.phone %></td>
            <td>
              <a href="/employees/edit/<%= e.id %>" class="btn btn-sm btn-warning" title="Edit"><i class="bi bi-pencil"></i></a>
              <a href="/employees/delete/<%= e.id %>" class="btn btn-sm btn-danger" title="Hapus" onclick="return confirm('Yakin hapus pegawai ini?')"><i class="bi bi-trash"></i></a>
            </td>
          </tr>
          <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../layouts/foot') %>