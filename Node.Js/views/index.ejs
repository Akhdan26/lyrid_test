<%- include('layouts/head') %>
<%- include('layouts/sidebar', { active: 'dashboard' }) %>
<%- include('layouts/navbar', { title: 'Dashboard' }) %>
  <h4 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h4>
  <div class="row g-4">
    <div class="col-md-6">
      <div class="card border-start border-4 border-primary shadow-sm"><div class="card-body text-center py-4">
        <div class="display-5 fw-bold text-primary"><%= typeof users !== 'undefined' ? users : 0 %></div>
        <small class="text-muted">Total Users</small></div></div>
    </div>
    <div class="col-md-6">
      <div class="card border-start border-4 border-success shadow-sm"><div class="card-body text-center py-4">
        <div class="display-5 fw-bold text-success"><%= typeof employees !== 'undefined' ? employees : 0 %></div>
        <small class="text-muted">Total Pegawai</small></div></div>
    </div>
  </div>
<%- include('layouts/foot') %>